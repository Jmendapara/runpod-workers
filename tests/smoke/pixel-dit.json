{
  "_NOTE": "Two-stage upscaler (ComfyUI API format) mirroring the prithivMLmods/PiD-Image-Upscaler HF Space. Stage 1: FLUX.2-Klein 4B distilled image-edit regenerates/deblurs the input at <=1024px (nodes 210-223; template image_flux2_klein_image_edit_4b_distilled). Stage 2: NVIDIA PiD flux1 super-resolves the refined image 4x (nodes 30-160). Node IDs match opensourcegen server/models/pixel-dit-upscale-workflow.json; width/height on 20/217/218/100 + checkpoint on 50 are patched server-side from the source image dimensions. Supply the input image via 'r2_inputs' (R2 key) or 'images' (base64) targeting node 10.",
  "workflow": {
    "10": { "class_type": "LoadImage", "inputs": { "image": "__INPUT_IMAGE__.png", "upload": "image" }, "_meta": { "title": "Load Image (r2 target)" } },
    "20": { "class_type": "ImageScale", "inputs": { "image": ["10", 0], "upscale_method": "lanczos", "width": 1024, "height": 1024, "crop": "disabled" }, "_meta": { "title": "Resize input (<=1024)" } },

    "210": { "class_type": "UNETLoader", "inputs": { "unet_name": "flux-2-klein-4b.safetensors", "weight_dtype": "default" }, "_meta": { "title": "Stage 1: FLUX.2-Klein model" } },
    "211": { "class_type": "CLIPLoader", "inputs": { "clip_name": "qwen_3_4b.safetensors", "type": "flux2", "device": "default" }, "_meta": { "title": "Stage 1: Qwen3 text encoder" } },
    "212": { "class_type": "VAELoader", "inputs": { "vae_name": "flux2-vae.safetensors" }, "_meta": { "title": "Stage 1: flux2 VAE" } },
    "213": { "class_type": "CLIPTextEncode", "inputs": { "text": "upscale", "clip": ["211", 0] }, "_meta": { "title": "Stage 1: refine prompt (matches HF Space)" } },
    "214": { "class_type": "ConditioningZeroOut", "inputs": { "conditioning": ["213", 0] }, "_meta": { "title": "Stage 1: negative (zeroed)" } },
    "215": { "class_type": "VAEEncode", "inputs": { "pixels": ["20", 0], "vae": ["212", 0] }, "_meta": { "title": "Stage 1: encode input (flux2)" } },
    "216": { "class_type": "ReferenceLatent", "inputs": { "conditioning": ["213", 0], "latent": ["215", 0] }, "_meta": { "title": "Stage 1: reference latent (img2img)" } },
    "217": { "class_type": "EmptyFlux2LatentImage", "inputs": { "width": 1024, "height": 1024, "batch_size": 1 }, "_meta": { "title": "Stage 1: empty flux2 canvas" } },
    "218": { "class_type": "Flux2Scheduler", "inputs": { "steps": 4, "width": 1024, "height": 1024 }, "_meta": { "title": "Stage 1: flux2 scheduler (4 step)" } },
    "219": { "class_type": "KSamplerSelect", "inputs": { "sampler_name": "euler" }, "_meta": { "title": "Stage 1: sampler (euler)" } },
    "220": { "class_type": "RandomNoise", "inputs": { "noise_seed": 0 }, "_meta": { "title": "Stage 1: noise" } },
    "221": { "class_type": "CFGGuider", "inputs": { "model": ["210", 0], "positive": ["216", 0], "negative": ["214", 0], "cfg": 1.0 }, "_meta": { "title": "Stage 1: guider (cfg 1)" } },
    "222": { "class_type": "SamplerCustomAdvanced", "inputs": { "noise": ["220", 0], "guider": ["221", 0], "sampler": ["219", 0], "sigmas": ["218", 0], "latent_image": ["217", 0] }, "_meta": { "title": "Stage 1: Klein sample" } },
    "223": { "class_type": "VAEDecode", "inputs": { "samples": ["222", 0], "vae": ["212", 0] }, "_meta": { "title": "Stage 1: decode refined image" } },

    "30": { "class_type": "VAELoader", "inputs": { "vae_name": "ae.safetensors" }, "_meta": { "title": "Stage 2: flux1/Z-Image VAE (encode)" } },
    "40": { "class_type": "VAEEncode", "inputs": { "pixels": ["223", 0], "vae": ["30", 0] }, "_meta": { "title": "Stage 2: encode refined image (flux1)" } },
    "50": { "class_type": "UNETLoader", "inputs": { "unet_name": "pid_flux1_1024_to_4096_4step_bf16.safetensors", "weight_dtype": "default" }, "_meta": { "title": "Stage 2: PiD checkpoint" } },
    "60": { "class_type": "CLIPLoader", "inputs": { "clip_name": "gemma_2_2b_it_elm_bf16.safetensors", "type": "pixeldit", "device": "default" }, "_meta": { "title": "Stage 2: Gemma text encoder" } },
    "70": { "class_type": "CLIPTextEncode", "inputs": { "text": "upscale", "clip": ["60", 0] }, "_meta": { "title": "Stage 2: positive (same prompt as Klein, matches HF Space)" } },
    "80": { "class_type": "CLIPTextEncode", "inputs": { "text": "low quality, worst quality, over-saturated, blurry, deformed, watermark", "clip": ["60", 0] }, "_meta": { "title": "Stage 2: negative" } },
    "90": { "class_type": "PiDConditioning", "inputs": { "positive": ["70", 0], "latent": ["40", 0], "latent_format": "flux", "degrade_sigma": 0 }, "_meta": { "title": "Stage 2: PiD conditioning" } },
    "100": { "class_type": "EmptyChromaRadianceLatentImage", "inputs": { "width": 4096, "height": 4096, "batch_size": 1 }, "_meta": { "title": "Stage 2: output canvas (4x)" } },
    "110": { "class_type": "KSamplerSelect", "inputs": { "sampler_name": "lcm" }, "_meta": { "title": "Stage 2: sampler (lcm)" } },
    "120": { "class_type": "ManualSigmas", "inputs": { "sigmas": "0.999,0.866,0.634,0.342,0" }, "_meta": { "title": "Stage 2: PiD sigma schedule" } },
    "130": { "class_type": "SamplerCustom", "inputs": { "add_noise": true, "noise_seed": 0, "cfg": 1.0, "model": ["50", 0], "positive": ["90", 0], "negative": ["80", 0], "sampler": ["110", 0], "sigmas": ["120", 0], "latent_image": ["100", 0] }, "_meta": { "title": "Stage 2: PiD sample" } },
    "140": { "class_type": "VAELoader", "inputs": { "vae_name": "pixel_space" }, "_meta": { "title": "Stage 2: PiD pixel-space VAE (decode)" } },
    "150": { "class_type": "VAEDecode", "inputs": { "samples": ["130", 0], "vae": ["140", 0] }, "_meta": { "title": "Stage 2: decode 4x output" } },
    "160": { "class_type": "SaveImage", "inputs": { "images": ["150", 0], "filename_prefix": "upscale/PixelDiT" }, "_meta": { "title": "Save Image" } }
  }
}
